SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Local DuckDB warehouse (single database for all schemas)
WAREHOUSE_DUCKDB_PATH=./pipeline/warehouse.duckdb

# Optional: MotherDuck cloud warehouse (set these and use DBT_TARGET=motherduck)
MOTHERDUCK_PATH=md:browserbase_warehouse
MOTHERDUCK_TOKEN=your-motherduck-token

# Optional: only needed when using dbt --target supabase
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_NAME=postgres
SUPABASE_DB_SCHEMA=public
